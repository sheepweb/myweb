                            };
                        default:
                            return { title: '', desc: '' };
                    }
                });

                // 切换视图方法并清空表单
                const switchView = (view) => {
                    currentView.value = view;
                    form.password = '';
                    form.confirmPassword = '';
                    // 实际应用中可能需要保留 email 方便用户
                };

                // 模拟API调用：登录
                const handleLogin = () => {
                    loading.value = true;
                    setTimeout(() => {
                        loading.value = false;
                        alert(`欢迎回来, ${form.email}。系统已验证您的贵宾身份。`);
                    }, 1500);
                };

                // 模拟API调用：注册
                const handleRegister = () => {
                    if (form.password !== form.confirmPassword) {
                        alert("两次输入的密码不一致，请重新确认。");
                        return;
                    }
                    loading.value = true;
                    setTimeout(() => {
                        loading.value = false;
                        alert(`尊敬的 ${form.lastName} 先生/女士，您的会籍申请已提交，我们将通过邮件发送确认函。`);
                        switchView('login');
                    }, 1500);
                };

                // 模拟API调用：忘记密码
                const handleForgot = () => {
                    loading.value = true;
                    setTimeout(() => {
                        loading.value = false;
                        alert(`重置链接已发送至：${form.email}。请查收并按照指示重置密码。`);
                        switchView('login');
                    }, 1500);
                };

                return {
                    currentView,
                    form,
                    loading,
                    getGreeting,
                    switchView,
                    handleLogin,
                    handleRegister,
                    handleForgot
                };
            }
        }).mount('#app');
    </script>
</body>
